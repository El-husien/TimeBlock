{
  "manifest_version": 3,
  "name": "TimeBlock",
  "version": "1.0.1",
  "description": "Track your time, block distractions, and achieve focus with Pomodoro techniques.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "webNavigation",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeBlock"
  },
  "options_page": "dashboard.html",
  "web_accessible_resources": []
}
